<% layout("/layouts/boilerplate.ejs") %>

<div class="container px-4 py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-xl-7">

      <div class="pg-form-card">

        <!-- Header -->
        <div style="display:flex; align-items:center; gap:18px; margin-bottom:36px;">
          <div class="brand-logo" style="width:52px; height:52px; font-size:1.1rem; flex-shrink:0;">
            <i class="fa-solid fa-pen"></i>
          </div>
          <div>
            <h2 class="pg-form-title">Edit Listing</h2>
            <p class="pg-form-subtitle">
              Update the details for <em><%= listing.title %></em>
            </p>
          </div>
        </div>

        <form
          method="POST"
          action="/listings/<%= listing._id %>?_method=PUT"
          novalidate
          class="needs-validation"
          enctype="multipart/form-data"
        >
          <!-- Title -->
          <div class="mb-4">
            <label for="title" class="form-label">PG / Hostel Name</label>
            <input
              name="listing[title]"
              id="title"
              value="<%= listing.title %>"
              type="text"
              class="form-control"
              required
            />
            <div class="valid-feedback">Looks great!</div>
          </div>

          <!-- Description -->
          <div class="mb-4">
            <label for="description" class="form-label">Description</label>
            <textarea
              name="listing[description]"
              id="description"
              class="form-control"
              required
            ><%= listing.description %></textarea>
            <div class="invalid-feedback">Please enter a description.</div>
          </div>

          <!-- Current Image Preview -->
          <div class="mb-4">
            <label class="form-label">Current Image</label>
            <div style="border-radius:14px; overflow:hidden; height:200px; background:var(--cream-2); border:1px solid var(--cream-3);">
              <img
                src="<%= originalImageUrl %>"
                alt="Current listing image"
                style="width:100%; height:100%; object-fit:cover;"
              />
            </div>
          </div>

          <!-- New Image Upload -->
          <div class="mb-4">
            <label for="image" class="form-label">Replace Image <span style="color:var(--ink-xsoft); font-weight:400; text-transform:none; letter-spacing:0;">(optional)</span></label>
            <input
              name="listing[image]"
              id="image"
              type="file"
              accept="image/*"
              class="form-control"
              style="padding: 11px 16px !important;"
            />
          </div>

          <!-- Price + Country -->
          <div class="row g-3 mb-4">
            <div class="col-md-5">
              <label for="price" class="form-label">Monthly Rent (₹)</label>
              <div style="position:relative;">
                <span style="position:absolute; left:16px; top:50%; transform:translateY(-50%); color:var(--ink-soft); font-size:0.9rem; z-index:1;">₹</span>
                <input
                  name="listing[price]"
                  id="price"
                  value="<%= listing.price %>"
                  type="number"
                  class="form-control"
                  style="padding-left:34px !important;"
                  required
                  min="0"
                />
              </div>
            </div>
            <div class="col-md-7">
              <label for="country" class="form-label">Country</label>
              <input
                name="listing[country]"
                id="country"
                value="<%= listing.country %>"
                type="text"
                class="form-control"
                required
              />
            </div>
          </div>

          <!-- Location -->
          <div class="mb-4">
            <label for="location" class="form-label">City / Location</label>
            <div style="position:relative;">
              <i class="fa-solid fa-location-dot" style="position:absolute; left:16px; top:50%; transform:translateY(-50%); color:var(--brand); font-size:0.875rem; z-index:1;"></i>
              <input
                name="listing[location]"
                id="location"
                value="<%= listing.location %>"
                type="text"
                class="form-control"
                style="padding-left:40px !important;"
                required
              />
            </div>
          </div>

          <hr style="border-color:var(--cream-3); margin:30px 0;" />

          <div class="d-flex gap-3 align-items-center flex-wrap">
            <button class="btn edit-btn" type="submit" style="min-width:170px;">
              <i class="fa-solid fa-floppy-disk me-2"></i>Save Changes
            </button>
            <a href="/listings/<%= listing._id %>" style="color:var(--ink-soft); font-size:0.875rem; text-decoration:none; font-weight:500;">
              Cancel
            </a>
          </div>
        </form>
      </div>

    </div>
  </div>
</div>
