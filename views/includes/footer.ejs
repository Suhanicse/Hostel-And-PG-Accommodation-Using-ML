<%# footer.ejs %>

<footer class="f-info">
  <div class="container text-center">

    <!-- Brand -->
    <div class="f-info-brand">
      <i class="fa-solid fa-bed" style="color:var(--brand); font-size:1rem;"></i>
      <span>Homelyt</span>
    </div>

    <!-- Tagline -->
    <p style="
      font-size:0.82rem; 
      color:rgba(255,255,255,0.45); 
      max-width:420px; 
      margin: 0 auto 18px; 
      line-height:1.7;
    ">
      Find safe, verified and affordable PG accommodations across Indian cities — designed for students and working professionals.
    </p>

    <!-- Trust line -->
    <p style="
      font-size:0.75rem; 
      color:rgba(255,255,255,0.28); 
      margin-bottom:18px;
    ">
      Real listings • Genuine reviews • Simple search
    </p>

    <!-- Social icons -->
    <div class="f-info-socials">
      <a href="#" title="Coming soon">
        <i class="fa-brands fa-square-facebook"></i>
      </a>

      <a href="#" title="Coming soon">
        <i class="fa-brands fa-square-instagram"></i>
      </a>

      <a href="#" title="Coming soon">
        <i class="fa-brands fa-linkedin"></i>
      </a>

      <a href="#" title="Coming soon">
        <i class="fa-brands fa-square-twitter"></i>
      </a>
    </div>

    <!-- Links -->
    <div class="f-info-links">
      <a href="/privacy">Privacy Policy</a>
      <a href="/terms">Terms of Service</a>
      <a href="/listings">All Listings</a>
      <a href="/listings/new">List Your PG</a>
    </div>

    <!-- Bottom -->
    <div style="
      margin-top: 24px;
      padding-top: 20px;
      border-top: 1px solid rgba(255,255,255,0.07);
      color: rgba(255,255,255,0.22);
      font-size: 0.72rem;
      letter-spacing: 0.03em;
    ">
      &copy; <%= new Date().getFullYear() %> Homelyt — Built with care for better living.
    </div>

  </div>
</footer>